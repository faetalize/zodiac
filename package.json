{
	"name": "zodiac",
	"private": true,
	"type": "module",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@types/marked": "^5.0.2",
		"@types/turndown": "^5.0.5",
		"@types/uuid": "^9.0.8",
		"@vitejs/plugin-basic-ssl": "^2.1.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"supabase": "^2.72.8",
		"tailwindcss": "^4.1.16",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.58.1",
		"vite": "^6.3.5",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@google/genai": "^1.34.0",
		"@supabase/supabase-js": "^2.53.0",
		"@tailwindcss/vite": "^4.1.16",
		"buffer": "^6.0.3",
		"dexie": "^4.0.10",
		"dompurify": "^3.2.3",
		"highlight.js": "^11.11.1",
		"marked": "^15.0.11",
		"openai": "^6.2.0",
		"tippy.js": "^6.3.7",
		"turndown": "^7.2.0",
		"uuid": "^9.0.1"
	},
	"scripts": {
		"type-check": "tsc --noEmit",
		"dev": "vite",
		"devlocal": "vite --host",
		"build": "npm run type-check && vite build",
		"lint": "eslint . --cache",
		"lint:fix": "eslint . --cache --fix",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"test:vitest": "vitest run --config vitest.config.mts",
		"test": "npm run type-check && npm run test:vitest",
		"test:watch": "vitest --config vitest.config.mts",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:ci": "node scripts/test-ci.mjs",
		"prepare": "husky",
		"preview": "vite preview",
		"sync-db-types": "node scripts/sync-db-types.mjs",
		"create-worktree": "node scripts/create-worktree.mjs"
	},
	"lint-staged": {
		"*.{ts,tsx,js,mjs,cjs,json,css,html,md,yml,yaml}": [
			"prettier --write"
		]
	}
}
